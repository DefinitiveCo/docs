{
  "$schema": "https://mintlify.com/docs.json",
  "name": "Definitive Flash API",
  "theme": "mint",
  "colors": {
    "primary": "#ffc517",
    "light": "#ffc517",
    "dark": "#ffc517"
  },
  "api": {
    "openapi": "http://ddp.definitive.fi/v2/flash/openapi.json",
    "playground": {
      "display": "interactive"
    },
    "auth": {
      "method": "key",
      "name": "x-definitive-api-key",
      "default": "dpka_2bd021e7_6458_4042_9f20_b01c9a95c2a4"
    },
    "examples": {
      "autogenerate": true,
      "prefill": true,
      "languages": ["curl", "python", "javascript"]
    }
  },
  "contextual": {
    "options": ["copy", "view", "chatgpt", "claude", "cursor"]
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Overview",
        "groups": [
          {
            "group": "Flash",
            "pages": [
              "index",
              "getting-started",
              "supported-chains",
              "rate-limits",
              "security"
            ]
          }
        ]
      },
      {
        "tab": "AI",
        "groups": [
          {
            "group": "Agents",
            "pages": ["for-agents"]
          }
        ]
      },
      {
        "tab": "Docs",
        "groups": [
          {
            "group": "Flash",
            "openapi": "https://ddp.definitive.fi/v2/flash/openapi.json",
            "pages": ["POST /quote", "POST /order"]
          }
        ]
      }
    ]
  }
}
